---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<MainLayout title="All Posts">
  <h1 class="text-3xl mb-8">All Posts</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map((post) => (
      <a href={`/posts/${post.slug}`} class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
        <h2 class="text-xl font-semibold mb-2">{post.data.title}</h2>
        <p class="text-gray-600 mb-4">{post.data.excerpt || 'No excerpt available'}</p>
        {post.data.date && <p class="text-sm text-gray-500">{post.data.date.toDateString()}</p>}
      </a>
    ))}
  </div>
</MainLayout>