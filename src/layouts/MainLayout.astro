---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Kaggle-Inspired Blog</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body class="bg-gray-100 font-sans text-gray-800">
    <div class="flex min-h-screen">
      <!-- Left Sidebar -->
      <aside class="fixed w-64 bg-white shadow-md h-screen p-6 transform -translate-x-full md:translate-x-0 transition-transform duration-300" id="sidebar">
        <h1 class="text-2xl font-bold text-blue-500 mb-8">Blog</h1>
        <nav>
          <ul class="space-y-4">
            <li><a href="/" class="text-gray-600 hover:text-blue-500">Home</a></li>
            <li><a href="/posts" class="text-gray-600 hover:text-blue-500">Posts</a></li>
            <li><a href="/about" class="text-gray-600 hover:text-blue-500">About</a></li>
          </ul>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-8 md:ml-64">
        <button class="md:hidden p-2 bg-blue-500 text-white rounded mb-4" onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')">Toggle Menu</button>
        <slot />
      </main>
    </div>
  </body>
</html>